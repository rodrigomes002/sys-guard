<Window x:Class="UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:UI"
        Title="SysGuard" Height="400" Width="600">

    <Grid Margin="10">
        <TabControl>

            <!-- ===================== -->
            <!-- ABA WEBSITES -->
            <!-- ===================== -->
            <TabItem Header="Websites">
                <DockPanel>

                    <!-- BOTÃO ADICIONAR -->
                    <Button Content="+ Adicionar site"
                            DockPanel.Dock="Bottom"
                            Height="35"
                            Margin="0,10,0,0"
                            Command="{Binding AddWebsiteCommand}" />

                    <!-- LISTA -->
                    <ListBox ItemsSource="{Binding Websites}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8" Margin="2" Background="#EEE">
                                    <DockPanel>

                                        <!-- TEXTO -->
                                        <TextBlock Text="{Binding Target}"
                                                   VerticalAlignment="Center"
                                                   FontSize="14"/>

                                        <!-- BOTÃO REMOVER -->
                                        <Button Content="X"
                                                Width="30"
                                                Height="25"
                                                DockPanel.Dock="Right"
                                                Background="#FF6B6B"
                                                Foreground="White"
                                                FontWeight="Bold"
                                                Command="{Binding DataContext.RemoveWebsiteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" />

                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </DockPanel>
            </TabItem>

            <!-- ===================== -->
            <!-- ABA APPLICATIONS -->
            <!-- ===================== -->
            <TabItem Header="Applications">
                <DockPanel>

                    <!-- BOTÃO ADICIONAR -->
                    <Button Content="+ Adicionar app"
                            DockPanel.Dock="Bottom"
                            Height="35"
                            Margin="0,10,0,0"
                            Command="{Binding AddAppCommand}" />

                    <!-- LISTA -->
                    <ListBox ItemsSource="{Binding Applications}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8" Margin="2" Background="#EEE">
                                    <DockPanel>

                                        <!-- TEXTO -->
                                        <TextBlock Text="{Binding Target}"
                                                   VerticalAlignment="Center"
                                                   FontSize="14"/>

                                        <!-- BOTÃO REMOVER -->
                                        <Button Content="X"
                                                Width="30"
                                                Height="25"
                                                DockPanel.Dock="Right"
                                                Background="#FF6B6B"
                                                Foreground="White"
                                                FontWeight="Bold"
                                                Command="{Binding DataContext.RemoveAppCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" />

                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </DockPanel>
            </TabItem>

        </TabControl>
    </Grid>
</Window>